# Server Configuration
PORT=5001
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5001

# PayFast Payment Gateway
# Get your credentials at: https://www.payfast.co.za (Settings → Developer Settings)
PAYFAST_MERCHANT_ID=your_merchant_id
PAYFAST_MERCHANT_KEY=your_merchant_key
PAYFAST_PASSPHRASE=your_passphrase
PAYFAST_SANDBOX=true  # Set to false for production

# Uber Direct API (for delivery)
# Apply at: https://developer.uber.com (Uber Direct, not Rides)
UBER_CUSTOMER_ID=your_customer_id
UBER_CLIENT_ID=your_client_id
UBER_CLIENT_SECRET=your_client_secret
UBER_SANDBOX=true  # Set to false for production

# Twilio Configuration (SMS & Voice)
# Get your credentials at: https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+18125563620

# GoHighLevel (GHL) Integration
GHL_API_KEY=your_ghl_api_key
GHL_LOCATION_ID=your_ghl_location_id
GHL_WEBHOOK_URL=your_ghl_webhook_url_here

# Database
# SQLite database is stored in ../database/royalsmoke.db
